# DeepSeek API 配置
# 为空时服务仍可启动，并自动使用规则引擎降级。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# 服务配置
# Docker 内部固定监听 0.0.0.0:8002；SERVICE_PORT 同时作为 compose 暴露到宿主机的端口。
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8002

# 请求配置
REQUEST_TIMEOUT=30
MAX_CODE_LINES=3000
